{
  "id": "intelli-integration",
  "title": "Intelli 集成项目",
  "version": "0.1.3",
  "providers": [
    {
      "id": "automation",
      "title": "Intelli 集成项目自动化",
      "icon": "bolt.rectangle",
      "statusFile": "runtime/status.json",
      "configFile": "runtime/config.json",
      "command": "bin/intelli-integration-provider",
      "arguments": [],
      "workingDirectory": ".",
      "configuration": [
        {
          "id": "notification",
          "title": "钉钉通知",
          "fields": [
            {
              "key": "notifications.dingtalk.enabled",
              "title": "启用通知",
              "type": "toggle",
              "defaultValue": "false",
              "help": "运行完成后发送简介和产出链接到钉钉机器人"
            },
            {
              "key": "notifications.dingtalk.webhook",
              "title": "机器人 Webhook",
              "type": "password",
              "placeholder": "https://oapi.dingtalk.com/robot/send?access_token=..."
            },
            {
              "key": "notifications.dingtalk.secret",
              "title": "加签 Secret",
              "type": "password",
              "placeholder": "SEC..."
            },
            {
              "key": "notifications.dingtalk.jobTypes",
              "title": "通知 Job",
              "type": "multiselect",
              "defaultValue": "daily-feedback-defect-triage,track-sprint-demand-progress",
              "options": [
                { "value": "daily-feedback-defect-triage", "title": "每日反馈缺陷分析" },
                { "value": "track-sprint-demand-progress", "title": "迭代进度追踪" },
                { "value": "prepare-sprint-iteration", "title": "迭代需求整理" },
                { "value": "production-log-analysis", "title": "生产日志分析" }
              ]
            }
          ]
        }
      ]
    }
  ]
}
