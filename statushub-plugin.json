{
  "id": "intelli-integration",
  "title": "Intelli 集成项目",
  "version": "0.1.8",
  "providers": [
    {
      "id": "automation",
      "title": "Intelli 集成项目自动化",
      "icon": "bolt.rectangle",
      "statusFile": "runtime/status.json",
      "configFile": "runtime/config.json",
      "command": "bin/intelli-integration-provider",
      "arguments": [],
      "workingDirectory": ".",
      "configuration": [
        {
          "id": "notification",
          "title": "钉钉通知",
          "fields": [
            {
              "key": "notifications.dingtalk.enabled",
              "title": "启用通知",
              "type": "toggle",
              "defaultValue": "false",
              "help": "运行完成后发送简介和产出链接到钉钉机器人"
            },
            {
              "key": "notifications.dingtalk.accessToken",
              "title": "机器人 Token",
              "type": "password",
              "placeholder": "复制 access_token= 后面的内容",
              "help": "只需要填写钉钉机器人 Webhook 中 access_token= 后面的 token，provider 会自动拼接固定地址"
            },
            {
              "key": "notifications.dingtalk.secret",
              "title": "加签 Secret",
              "type": "password",
              "placeholder": "SEC...",
              "help": "仅当钉钉机器人安全设置开启“加签”时填写；未开启加签时留空"
            },
            {
              "key": "notifications.dingtalk.jobTypes",
              "title": "通知 Job",
              "type": "multiselect",
              "defaultValue": "daily-feedback-defect-triage",
              "options": [
                { "value": "daily-feedback-defect-triage", "title": "每日反馈缺陷分析" },
                { "value": "prepare-sprint-iteration", "title": "迭代需求整理" },
                { "value": "production-log-analysis", "title": "生产日志分析" }
              ]
            }
          ]
        }
      ]
    }
  ]
}
