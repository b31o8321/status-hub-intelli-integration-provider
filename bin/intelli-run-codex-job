#!/usr/bin/env python3
from __future__ import annotations

from datetime import datetime
from pathlib import Path
import json
import os
import shutil
import subprocess
import sys
import tempfile


ROOT = Path(__file__).resolve().parents[1]
SRC = ROOT / "src"
if str(SRC) not in sys.path:
    sys.path.insert(0, str(SRC))

from statushub_intelli_provider.config import load_config


CODEX_WORKDIR = Path(
    os.environ.get("INTELLI_CODEX_WORKDIR")
    or "/Users/norman/development/vibe-coding/shulex-intelli"
)
RESULT_SCHEMA = ROOT / "config" / "codex-job-result.schema.json"
KNOWN_CODEX_PATHS = [
    Path("/Users/norman/.nvm/versions/node/v20.20.2/bin/codex"),
]


def main() -> int:
    job_type = os.environ.get("INTELLI_JOB_TYPE", "").strip()
    trigger = os.environ.get("INTELLI_JOB_TRIGGER", "manual").strip()
    config = load_config()
    job_config = find_job(config, job_type)
    if not job_config:
        emit_result(
            {
                "status": "failed",
                "summary": f"未知 Job：{job_type or '(empty)'}",
                "note": "provider 配置中找不到对应 jobType。",
            }
        )
        return 2

    codex_bin = find_codex()
    if not codex_bin:
        emit_result(
            {
                "status": "failed",
                "summary": f"{job_type} 未执行：找不到 codex CLI",
                "note": "请确认本机已安装 Codex CLI，或通过 CODEX_BIN 指定路径。",
            }
        )
        return 127

    with tempfile.TemporaryDirectory(prefix="status-hub-codex-") as tmp_dir:
        last_message = Path(tmp_dir) / "last-message.txt"
        prompt = build_prompt(job_type, trigger, job_config, config)
        command = [
            codex_bin,
            "exec",
            "-C",
            str(CODEX_WORKDIR),
            "--dangerously-bypass-approvals-and-sandbox",
            "--output-schema",
            str(RESULT_SCHEMA),
            "--output-last-message",
            str(last_message),
            prompt,
        ]
        completed = subprocess.run(
            command,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            check=False,
        )
        if completed.stdout:
            print(completed.stdout, end="")

        final_text = read_text(last_message).strip()
        result = parse_json_result(final_text)
        if not result:
            result = {
                "status": "failed",
                "summary": f"{job_type} 执行完成但未返回可解析 JSON",
                "note": "Codex 最后一条消息必须只包含固定结构 JSON；请查看本次 log。",
            }
        if completed.returncode != 0:
            result.setdefault("status", "failed")
            result["status"] = "failed"
            result.setdefault("summary", f"{job_type} 执行失败")
            result.setdefault("note", f"codex exec 退出码：{completed.returncode}")
        emit_result(result)
        return completed.returncode


def find_job(config: dict, job_type: str) -> dict:
    for job in config.get("jobs", []):
        if isinstance(job, dict) and job.get("jobType") == job_type:
            return job
    return {}


def find_codex() -> str:
    configured = os.environ.get("CODEX_BIN", "").strip()
    if configured and Path(configured).exists():
        return configured
    discovered = shutil.which("codex")
    if discovered:
        return discovered
    for path in KNOWN_CODEX_PATHS:
        if path.exists():
            return str(path)
    return ""


def build_prompt(job_type: str, trigger: str, job_config: dict, config: dict) -> str:
    skill = str(job_config.get("skill") or "").strip()
    today = datetime.now().astimezone().strftime("%Y-%m-%d")
    common = f"""
你是 Status Hub 的 Intelli 集成自动化执行进程。请在当前本机环境真实执行任务，不要只给计划。

执行上下文：
- jobType: {job_type}
- trigger: {trigger}
- today: {today}
- sprintRootFolderUrl: {config.get("sprintRootFolderUrl", "")}
- integrationDemandTable: {config.get("sourceLinks", {}).get("integrationDemandTable", "")}
- iterationRequirementTable: {config.get("sourceLinks", {}).get("iterationRequirementTable", "")}
- iterationRequirementDevelopmentView: {config.get("sourceLinks", {}).get("iterationRequirementDevelopmentView", "")}

执行要求：
- 必须使用 ${skill} skill。
- 需要创建或更新钉钉产出文档时，直接通过 MCP 完成。
- 不要调用 provider 的 bin/intelli-integration-job record；provider 会解析你的最终 JSON 并统一写运行记录。
- 不要直接调用钉钉机器人发送消息；如需通知，请返回 notificationMarkdown 和 notifyAtUserIds，由 provider 根据配置发送。
- notificationMarkdown 正文中提醒负责人时必须使用 `@显示名`，例如“@许嘉凯Xjk：...”；不要写 `@17417778857341994` 这类 userId，也不要用 userId 当显示文本。
- 需要真正 @ 人时，只把钉钉 userId 放到 notifyAtUserIds 数组里。
- 如果无法完成真实执行，返回 status=failed，并在 note 写明阻塞原因。

最后一条回复必须只输出一个 JSON 对象，不能使用 markdown 代码块，不能附加解释文字。所有字段都必须包含；没有值时，字符串字段用 null，数组字段用 []。结构如下：
{{
  "status": "success|failed|needs_confirmation",
  "summary": "一句话说明本次执行结果",
  "sprint": "Sprint 名称或 null",
  "artifacts": [
    {{"title": "产出文档标题", "url": "https://alidocs.dingtalk.com/i/nodes/..."}}
  ],
  "notificationMarkdown": "钉钉 markdown 汇总消息或 null，正文用 @显示名，不写 @userId",
  "notifyAtUserIds": ["钉钉 userId，仅用于真实 at，没有则返回空数组"],
  "note": "补充说明、人工确认项或 null"
}}
""".strip()
    return common + "\n\n" + job_instruction(job_type)


def job_instruction(job_type: str) -> str:
    if job_type == "daily-feedback-defect-triage":
        return """
本次任务：
- 只分析“集成项目”相关的每日缺陷分类；非集成模块不要进入日报、通知和 summary 计数。
- 集成相关范围：反馈模块/子模块/标题/描述明显属于工单系统集成、关键数据集成、Omini Channel、Chatflow 中的集成调用、授权/消息收发/Webhook/物流查询/订单商品客户数据同步等集成链路。
- 明确排除非集成模块，例如纯 Livechat 产品体验、Agent 广场、计费/账户、skill 配置、普通 AI 回复质量等；除非记录内容直接指向集成链路故障。
- 按反馈内容所属集成子模块分配 Owner，整理排查/修复建议。
- 同时读取项目管理表中本周计划完成且进行中的集成需求，提醒负责人更新进度或反馈卡点。
- 在当前 Sprint 迭代文件夹中创建或更新当天文档，标题形如“每日反馈与进度提醒 YYYY-MM-DD”。
- 返回 artifacts 至少包含当天钉钉文档链接。
- 返回 notificationMarkdown，用于群内汇总提醒相关 Owner；正文用 @显示名，真实 at 只通过 notifyAtUserIds。
- notificationMarkdown 里必须包含缺陷反馈源表 integrationDemandTable 和本周进行中需求视图 iterationRequirementDevelopmentView 的链接，方便收到消息的人直接跳转查看详情。
""".strip()
    if job_type == "prepare-sprint-iteration":
        return """
本次任务：
- 准备下一轮集成项目迭代需求。
- 整理集成相关需求、人工补充需求、point 估算、优先级和原因。
- 需求整理文档的所有候选需求、人工补充、项目管理状态核对、生产日志和代码 ROI 表格都必须包含“参考源链接”列。
- 参考源链接至少包含：需求池源表 integrationDemandTable、项目管理需求表 iterationRequirementTable、进行中需求视图 iterationRequirementDevelopmentView；单条记录没有独立链接时，在链接旁写 recordId/需求编号/日志查询关键词。
- 数据来源与筛选口径模块必须集中贴出上述源表链接、SLS 路由和已检查代码路径，方便人工回看原始来源。
- 生产日志第一层查询使用 `__tag__:service : shulex-intelli and severity : ERROR`，先聚合高频错误签名，再筛选集成相关链路。
- 如果 SLS 查询失败是本机 OAuthProfile/token 过期，不要把它写进“生产日志整理出的需求与优化”表格；只在数据来源或 note 中说明“刷新 OAuthProfile 后重跑”。
- 对本次文档中选中的集成需求，写入项目管理表 `产研需求管理` 的“待评审”视图；写入前必须检查 `关联客户需求` 和相似需求，已存在或疑似存在时不要重复创建。
- 新建项目管理需求时，状态必须为“待评审”，业务单元必须归到集成相关模块；创建后把需求编号/链接写回需求整理文档的“项目管理需求”列。
- 单独列出“项目管理已完成但需求池未更新”的候选项，提醒人工确认后更新。
- 创建或更新 Sprint 文件夹中的需求整理文档。
- 返回 artifacts 至少包含需求整理文档链接。
""".strip()
    if job_type == "production-log-analysis":
        return """
本次任务：
- 只做生产环境集成服务高频 error 日志分析。
- 生产 SLS project 必须使用 shulex-prod-applications-0714。
- 第一层查询使用 `__tag__:service : shulex-intelli and severity : ERROR`，先聚合高频错误签名，再筛选集成相关链路。
- 如果 SLS 查询失败是本机 OAuthProfile/token 过期，不要生成日志派生需求；返回 failed 或在 note 中说明需要刷新 OAuthProfile 后重跑。
- 输出降噪/修复候选，不要混入迭代需求整理，除非用户后续人工确认。
- 如创建文档，返回 artifacts 文档链接。
""".strip()
    return "按 jobType 对应 skill 执行，并返回固定 JSON。"


def read_text(path: Path) -> str:
    try:
        return path.read_text(encoding="utf-8")
    except OSError:
        return ""


def parse_json_result(value: str) -> dict:
    value = strip_code_fence(value.strip())
    if not value:
        return {}
    try:
        parsed = json.loads(value)
    except json.JSONDecodeError:
        return {}
    return parsed if isinstance(parsed, dict) else {}


def strip_code_fence(value: str) -> str:
    if value.startswith("```"):
        lines = value.splitlines()
        if len(lines) >= 2 and lines[-1].strip() == "```":
            return "\n".join(lines[1:-1]).strip()
    return value


def emit_result(payload: dict) -> None:
    print("STATUS_HUB_RESULT_JSON_BEGIN")
    print(json.dumps(payload, ensure_ascii=False, indent=2))
    print("STATUS_HUB_RESULT_JSON_END")


if __name__ == "__main__":
    raise SystemExit(main())
